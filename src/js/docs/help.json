  {"text": "╔══════════════════════════════════════╗", "style": "color: #e74c3c"},
  {"text": "║            SADRAZAM v1.0             ║", "style": "color: #e74c3c; font-weight: bold; font-size: 14px"},
  {"text": "╚══════════════════════════════════════╝", "style": "color: #e74c3c"},
  {"text": "", "style": ""},
  {"text": "▸ Servisler", "style": "font-weight: bold; font-size: 12px; color: #2c3e50"},
  {"text": "  Ajax             Promise tabanli HTTP istek yoneticisi (GET/POST, spinner, timeout)", "style": ""},
  {"text": "  LogRelay         Global JS hata yakalama ve backend'e iletme servisi", "style": ""},
  {"text": "  Language         Statik coklu dil yoneticisi (i18n)", "style": ""},
  {"text": "", "style": ""},
  {"text": "▸ UI Bilesenleri", "style": "font-weight: bold; font-size: 12px; color: #2c3e50"},
  {"text": "  Modal            Modal pencere yoneticisi", "style": ""},
  {"text": "  Toast            Modal tabanli toast bildirim yoneticisi", "style": ""},
  {"text": "  Snackbar         Toast bildirim yoneticisi (singleton)", "style": ""},
  {"text": "  Spinner          Yukleme gostergesi (reference counting)", "style": ""},
  {"text": "  ProgressBar      Sayfa ust yukleme cubugu (top loading bar)", "style": ""},
  {"text": "  Tabs             Sekme navigasyonu", "style": ""},
  {"text": "  Tooltip          Arac ipucu", "style": ""},
  {"text": "  Popover          Acilir bilgi kutusu", "style": ""},
  {"text": "  Hovermenu        Dropdown acilir menu", "style": ""},
  {"text": "  SlideMenu        Kayarak acilan menu (mobil uyumlu)", "style": ""},
  {"text": "  Backdrop         Arka plan perdesi", "style": ""},
  {"text": "  Autocomplete     Otomatik tamamlama input'u", "style": ""},
  {"text": "  InfiniteScroll   Sonsuz kaydirma", "style": ""},
  {"text": "", "style": ""},
  {"text": "▸ Form & Input", "style": "font-weight: bold; font-size: 12px; color: #2c3e50"},
  {"text": "  Form             Kural tabanli form dogrulama (data-fvalidate)", "style": ""},
  {"text": "  AutosizeTextarea Icerigi gore otomatik yukseklik", "style": ""},
  {"text": "  AutosizeSelect   Icerigi gore otomatik genislik", "style": ""},
  {"text": "", "style": ""},
  {"text": "▸ DOM & Yardimcilar", "style": "font-weight: bold; font-size: 12px; color: #2c3e50"},
  {"text": "  Elem             DOM element yardimcilari (stil, boyut, scroll)", "style": ""},
  {"text": "  Document         Sayfa yonlendirme, metin kopyalama, UUID", "style": ""},
  {"text": "  InsertScript     AJAX ile yuklenen HTML icindeki script calistirici", "style": ""},
  {"text": "  Url              URL parametre yonetimi (get/set/delete)", "style": ""},
  {"text": "  Token            CSRF token yonetimi", "style": ""},
  {"text": "  Cookie           Cookie CRUD", "style": ""},
  {"text": "  Event            addEventListener wrapper", "style": ""},
  {"text": "  ScrollHistory    Scroll pozisyon hafizasi", "style": ""},
  {"text": "", "style": ""},
  {"text": "▸ Cihaz & Ortam", "style": "font-weight: bold; font-size: 12px; color: #2c3e50"},
  {"text": "  browser          Tarayici algilama", "style": ""},
  {"text": "  Device           Cihaz algilama", "style": ""},
  {"text": "  Viewport         Goruntu alani yardimcilari", "style": ""},
  {"text": "", "style": ""},
